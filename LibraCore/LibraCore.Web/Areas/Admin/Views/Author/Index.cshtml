@model IEnumerable<AuthorViewModel>

@{
	ViewData["Title"] = "Manage Authors";
}

@section Styles {
	<link rel="stylesheet" href="~/css/author-index.css" asp-append-version="true" />
}

<div class="container mt-4">
	<div class="d-flex justify-content-between align-items-center mb-4">
		<h2 class="fw-bold text-white">Manage Authors</h2>
		<a asp-action="Add" class="btn btn-success rounded-pill px-4">
			<i class="bi bi-plus-lg"></i> Add Author
		</a>
	</div>

	@if (TempData["Success"] != null)
	{
		<div class="alert alert-success">@TempData["Success"]</div>
	}

	@if (TempData["Error"] != null)
	{
		<div class="alert alert-danger">@TempData["Error"]</div>
	}

	<div class="table-responsive">
		<table class="table table-bordered table-hover align-middle admin-table">
			<thead class="table-dark">
				<tr>
					<th style="width: 50px;">#</th>
					<th>Name</th>
					<th style="width: 120px;">Actions</th>
				</tr>
			</thead>
			<tbody>
				@foreach (var author in Model.Select((a, i) => new { a, i }))
				{
					<tr>
						<td>@(author.i + 1)</td>
						<td>@author.a.Name</td>
						<td>
							<a asp-action="Delete" asp-route-id="@author.a.Id"
							   class="btn btn-danger btn-sm rounded-pill w-100">
								<i class="bi bi-trash"></i> Delete
							</a>
						</td>
					</tr>
				}
			</tbody>
		</table>
	</div>
</div>