@model AuthorInputModel

@{
    ViewData["Title"] = "Add Author";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 rounded-4 p-4">
                <h3 class="fw-bold mb-4 text-center">Add New Author</h3>

                <form asp-action="Add" method="post">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold"></label>
                        <input asp-for="Name" class="form-control rounded-pill px-3"
                               placeholder="Enter author name" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-success rounded-pill">
                            <i class="bi bi-plus-lg"></i> Add Author
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<partial name="_ValidationScriptsPartial" />