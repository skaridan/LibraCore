@model AuthorViewModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5 text-center bg-white p-5 rounded-4 shadow-lg">

            <i class="bi bi-person" style="font-size: 3rem; color: #dc3545;"></i>

            <h2 class="fw-bold mt-3">Delete Author?</h2>
            <p class="text-muted">Are you sure you want to delete <strong>@Model.Name</strong>?</p>

            <form asp-area="Admin" asp-controller="Author" asp-action="Delete" method="post" class="mt-4">
                <input type="hidden" name="id" value="@Model.Id" />

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-danger btn-lg rounded-pill">Yes, Delete</button>
                    <a asp-area="Admin" asp-controller="Author" asp-action="Index" class="btn btn-outline-secondary btn-lg rounded-pill">No, Cancel</a>
                </div>
            </form>

        </div>
    </div>
</div>