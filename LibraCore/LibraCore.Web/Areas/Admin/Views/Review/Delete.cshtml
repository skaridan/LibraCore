@model ReviewViewModel

@{
    ViewData["Title"] = "Delete Review";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5 text-center bg-white p-5 rounded-4 shadow-lg">

            <i class="bi bi-chat-left-text text-danger mb-3" style="font-size: 3rem;"></i>
            <h2 class="fw-bold">Delete Review?</h2>
            <p class="text-muted">Are you sure you want to delete this review by <strong>@Model.UserName</strong>?</p>

            <div class="mb-3">
                @for (int i = 1; i <= 5; i++)
                {
                    <i class="bi @(i <= Model.Rating ? "bi-star-fill text-warning" : "bi-star text-muted")"></i>
                }
            </div>

            <p class="text-muted fst-italic">"@Model.Comment"</p>

            <form asp-action="Delete" method="post" class="mt-4">
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="BookId" value="@Model.BookId" />

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-danger btn-lg rounded-pill">Yes, Delete</button>
                    <a asp-area="" asp-controller="Review" asp-action="Index" asp-route-bookId="@Model.BookId"
                       class="btn btn-outline-secondary btn-lg rounded-pill">No, Keep it</a>
                </div>
            </form>

        </div>
    </div>
</div>