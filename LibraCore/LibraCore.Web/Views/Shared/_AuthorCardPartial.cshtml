@model AuthorViewModel

<div class="col-md-4 col-lg-3">
    <div class="card h-100 shadow-sm author-card text-center p-3 border-0">
        <div class="d-flex justify-content-center mb-3">
            <div class="avatar-circle">
                @Model.Name[0]
            </div>
        </div>
        <div class="card-body">
            <h5 class="card-title fw-bold mb-1 text-dark">@Model.Name</h5>
        </div>
    </div>
</div>