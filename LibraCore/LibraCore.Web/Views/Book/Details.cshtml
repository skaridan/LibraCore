@using LibraCore.ViewModels.Book
@model BookDetailsViewModel

@{
	ViewData["Title"] = "Book Details";
}

<div class="container mt-5">
	<div class="feature-card bg-white rounded-4 shadow-lg overflow-hidden border-0">
		<div class="row g-0">
			<div class="col-md-4 bg-light d-flex align-items-center justify-content-center p-4">
				@if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
				{
					<img src="@Model.ImageUrl" alt="@Model.Title" class="img-fluid rounded-3 shadow" style="max-height: 450px; object-fit: cover;">
				}
				else
				{
					<div class="text-muted text-center">
						<i class="bi bi-book" style="font-size: 5rem;"></i>
						<p>No Image Available</p>
					</div>
				}
			</div>

			<div class="col-md-8 p-5">
				<div class="d-flex justify-content-between align-items-start mb-3">
					<div>
						<h1 class="fw-bold text-dark display-5 mb-1">@Model.Title</h1>
						<p class="fs-4 text-secondary mb-0">by <span class="text-primary fw-bold">@Model.Author</span></p>
					</div>
					<span class="badge bg-success bg-opacity-10 text-success rounded-pill px-4 py-2 fs-4 border border-success border-opacity-25">
						@Model.Price.ToString("F2") €
					</span>
				</div>

				<div class="d-flex gap-3 mb-4">
					<span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2">
						<i class="bi bi-tag-fill me-1"></i> @Model.Genre
					</span>
					<span class="badge bg-info bg-opacity-10 text-info rounded-pill px-3 py-2">
						<i class="bi bi-calendar-event me-1"></i> Released: @Model.ReleaseDate
					</span>
				</div>

				<h5 class="fw-bold text-dark mb-3">Description</h5>
				<p class="text-muted fs-5 lh-lg mb-5">
					@Model.Description
				</p>

				<div class="d-flex gap-3 pt-4 border-top">
					<a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 py-2">
						<i class="bi bi-arrow-left"></i> Back to Catalog
					</a>
					@if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
					{
						<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning rounded-pill px-4 py-2 fw-bold text-white shadow-sm">
							<i class="bi bi-pencil-square"></i> Edit Book
						</a>

						<a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger rounded-pill px-4 py-2 fw-bold shadow-sm">
							<i class="bi bi-trash"></i> Delete Book
						</a>
					}
				</div>
			</div>
		</div>
	</div>
</div>