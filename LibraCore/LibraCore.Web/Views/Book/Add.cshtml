@model BookInputFormModel

@{
	ViewData["Title"] = "Add New Book";
}

<div class="container mt-5">
	<div class="row justify-content-center">
		<div class="col-md-8">
			<div class="feature-card p-5">
				<div class="text-center mb-4">
					<i class="bi bi-plus-circle text-primary" style="font-size: 3rem;"></i>
					<h2 class="fw-bold text-dark">Add New Book</h2>
					<p class="text-muted">Fill in the details to expand the library</p>
				</div>
				<div asp-validation-summary="All"></div>

				<form asp-action="Add" method="post">

					<div class="row">
						<div class="col-md-12 mb-3">
							<label asp-for="Title" class="form-label fw-bold"></label>
							<input asp-for="Title" class="form-control rounded-pill px-4 py-2" placeholder="Enter book title..." />
							<span asp-validation-for="Title" class="text-danger small"></span>
						</div>

						<div class="col-md-6 mb-3">
							<label asp-for="GenreId" class="form-label fw-bold">Genre</label>
							<select asp-for="GenreId" class="form-select rounded-pill px-4 py-2"
									asp-items="@(new SelectList(Model.Genres, "Id", "Name"))">
								<option value="">-- Select Genre --</option>
							</select>
							<span asp-validation-for="GenreId" class="text-danger small"></span>
						</div>

						<div class="col-md-12 mb-3">
							<label asp-for="Description" class="form-label fw-bold"></label>
							<textarea asp-for="Description" class="form-control rounded-4 px-4" rows="3" placeholder="Brief summary..."></textarea>
							<span asp-validation-for="Description" class="text-danger small"></span>
						</div>

						<div class="col-md-6 mb-3">
							<label asp-for="Author" class="form-label fw-bold">Author Name</label>
							<input asp-for="Author" class="form-control rounded-pill px-4 py-2" placeholder="Enter author name..." />
							<span asp-validation-for="Author" class="text-danger small"></span>
						</div>

						<div class="col-md-6 mb-3">
							<label asp-for="Price" class="form-label fw-bold"></label>
							<div class="input-group">
								<span class="input-group-text rounded-start-pill bg-light border-end-0">€</span>
								<input asp-for="Price" class="form-control rounded-end-pill py-2 border-start-0" placeholder="0.00" />
							</div>
							<span asp-validation-for="Price" class="text-danger small"></span>
						</div>

						<div class="col-md-4 mb-3">
							<label asp-for="ReleaseDate" class="form-label fw-bold">Release Date</label>
							<input asp-for="ReleaseDate" type="date" class="form-control rounded-pill px-4 py-2" />
							<span asp-validation-for="ReleaseDate" class="text-danger small"></span>
						</div>

						<div class="col-md-12 mb-4">
							<label asp-for="ImageUrl" class="form-label fw-bold"></label>
							<input asp-for="ImageUrl" class="form-control rounded-pill px-4 py-2" placeholder="https://image-url.com/book.jpg" />
							<span asp-validation-for="ImageUrl" class="text-danger small"></span>
						</div>
					</div>

					<div class="d-flex gap-3 mt-2">
						<button type="submit" class="btn btn-primary rounded-pill px-5 flex-grow-1 fw-bold">
							Create Book
						</button>
						<a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
							Cancel
						</a>
					</div>
				</form>
			</div>
		</div>
	</div>
</div>

@section Scripts {
	<partial name="_ValidationScriptsPartial" />
}