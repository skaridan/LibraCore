@model BookInputFormModel

@{
    ViewData["Title"] = "Edit Book";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="feature-card bg-white p-5 rounded-4 shadow-lg border-top border-5 border-warning">
                <div class="d-flex align-items-center mb-4">
                    <div class="bg-warning bg-opacity-10 p-3 rounded-circle me-3">
                        <i class="bi bi-pencil-square text-warning fs-3"></i>
                    </div>
                    <div>
                        <h1 class="fw-bold text-dark mb-0">Edit Book</h1>
                        <p class="text-muted mb-0">Update the information for your book</p>
                    </div>
                </div>

                <hr class="mb-4 opacity-10">
                <div asp-validation-summary="All"></div>

                <form asp-action="Edit" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <input type="hidden" name="id" value="@Context.Request.RouteValues["id"]" />

                    <div class="row g-3">
                        <div class="col-md-12">
                            <label asp-for="Title" class="form-label fw-bold small text-uppercase text-muted">Book Title</label>
                            <input asp-for="Title" class="form-control form-control-lg rounded-3 shadow-sm" placeholder="Enter book title..." />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Author" class="form-label fw-bold small text-uppercase text-muted">Author Name</label>
                            <input asp-for="Author" class="form-control rounded-3 shadow-sm" placeholder="e.g. George Orwell" />
                            <span asp-validation-for="Author" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="GenreId" class="form-label fw-bold small text-uppercase text-muted">Genre</label>
                            <select asp-for="GenreId" class="form-select rounded-3 shadow-sm">
                                <option value="">-- Select Genre --</option>
                                @foreach (var genre in Model.Genres)
                                {
                                    <option value="@genre.Id">@genre.Name</option>
                                }
                            </select>
                            <span asp-validation-for="GenreId" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Price" class="form-label fw-bold small text-uppercase text-muted">Price (€)</label>
                            <div class="input-group shadow-sm rounded-3 overflow-hidden">
                                <span class="input-group-text border-0 bg-light">€</span>
                                <input asp-for="Price" type="number" step="0.01" class="form-control border-0" />
                            </div>
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ReleaseDate" class="form-label fw-bold small text-uppercase text-muted">Release Date</label>
                            <input asp-for="ReleaseDate" type="date" class="form-control rounded-3 shadow-sm" />
                            <span asp-validation-for="ReleaseDate" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="ImageUrl" class="form-label fw-bold small text-uppercase text-muted">Cover Image URL</label>
                            <input asp-for="ImageUrl" class="form-control rounded-3 shadow-sm" placeholder="https://example.com/image.jpg" />
                            <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Description" class="form-label fw-bold small text-uppercase text-muted">Description</label>
                            <textarea asp-for="Description" rows="4" class="form-control rounded-3 shadow-sm" placeholder="Tell us about this book..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-3 mt-5">
                        <button type="submit" class="btn btn-warning btn-lg rounded-pill px-5 fw-bold text-white shadow">
                            <i class="bi bi-check-lg me-2"></i> Save Changes
                        </button>
                        <a asp-action="Details" asp-route-id="@Context.Request.RouteValues["id"]" class="btn btn-outline-secondary btn-lg rounded-pill px-4">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}