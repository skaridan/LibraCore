@model IEnumerable<BookIndexViewModel>

@{
    ViewData["Title"] = "All Books";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-5 p-3 bg-white rounded-4 shadow-sm">
        <div>
            <h1 class="fw-bold text-primary mb-0">Library Catalog</h1>
            <p class="text-muted mb-0">Manage and explore your book collection</p>
        </div>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 fw-bold">
            <i class="bi bi-plus-lg"></i> Add New Book
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-secondary text-center shadow-sm rounded-4 py-5">
            <i class="bi bi-book text-muted d-block mb-3" style="font-size: 3rem;"></i>
            <h4 class="fw-bold">No books found.</h4>
            <p>Start by adding your first masterpiece to the collection!</p>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var book in Model)
            {
                <div class="card border-0 rounded-4 shadow-sm p-3 book-card-list d-flex flex-row align-items-center">

                    <div class="flex-shrink-0">
                        @if (!string.IsNullOrWhiteSpace(book.ImageUrl))
                        {
                            <img src="@book.ImageUrl" alt="@book.Title" class="book-cover-img rounded-3 shadow-sm">
                        }
                        else
                        {
                            <div class="book-cover-img rounded-3 bg-light d-flex align-items-center justify-content-center border text-muted">
                                <i class="bi bi-image" style="font-size: 2rem;"></i>
                            </div>
                        }
                    </div>

                    <div class="card-body ms-4 p-0">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h4 class="fw-bold text-dark mb-1">@book.Title</h4>
                                <h6 class="text-secondary mb-3">by <span class="fw-bold">@book.Author.Name</span></h6>
                            </div>
                            <div class="text-end">
                                <span class="h5 fw-bold text-primary d-block mb-0">@book.Price.ToString("F2") €</span>
                                <small class="text-muted">Price</small>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-2">
                            <a asp-action="Details" asp-route-id="@book.Id" class="btn btn-sm btn-outline-info rounded-pill px-3">
                                <i class="bi bi-eye"></i> Details
                            </a>
                            <a asp-action="Edit" asp-route-id="@book.Id" class="btn btn-sm btn-outline-warning rounded-pill px-3">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            <a asp-action="Delete" asp-route-id="@book.Id"
                               class="btn btn-sm btn-outline-danger rounded-pill px-3"
                               onclick="return confirm('Are you sure you want to delete this book?');">
                                <i class="bi bi-trash"></i> Delete
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>