@model IEnumerable<BookIndexViewModel>

@{
	ViewData["Title"] = "All Books";
}

@section Styles {
	<link rel="stylesheet" href="~/css/book-index.css" asp-append-version="true" />
}

<div class="container mt-4">
	<div class="d-flex justify-content-between align-items-center mb-5 p-4 bg-white rounded-4 shadow-sm border-start border-5 border-primary">
		<div>
			<h1 class="fw-bold text-dark mb-0">Library Catalog</h1>
			<p class="text-muted mb-0">Manage and explore your book collection</p>
		</div>
		@if (User.Identity?.IsAuthenticated == true)
		{
			<a asp-action="Add" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
				<i class="bi bi-plus-lg"></i> Add New Book
			</a>
		}
	</div>

	@if (!Model.Any())
	{
		<div class="feature-card text-center py-5">
			<i class="bi bi-book text-muted d-block mb-3" style="font-size: 3rem;"></i>
			<h4 class="fw-bold text-dark">No books found.</h4>
			<p class="text-muted">Start by adding your first masterpiece to the collection!</p>
		</div>
	}
	else
	{
		<div class="row g-4">
			@foreach (var book in Model)
			{
				<div class="col-12">
					<div class="feature-card d-flex align-items-center p-0 overflow-hidden" style="min-height: 180px;">

						<div class="book-list-cover-wrapper flex-shrink-0">
							@if (!string.IsNullOrWhiteSpace(book.ImageUrl))
							{
								<img src="@book.ImageUrl" alt="@book.Title" class="book-list-img">
							}
							else
							{
								<div class="book-list-img bg-light d-flex align-items-center justify-content-center text-muted">
									<i class="bi bi-book" style="font-size: 2rem;"></i>
								</div>
							}
						</div>

						<div class="flex-grow-1 p-4 d-flex flex-column justify-content-between">
							<div class="d-flex justify-content-between align-items-start w-100">
								<div>
									<h3 class="fw-bold text-dark mb-1">@book.Title</h3>
									<p class="text-secondary mb-0">by <span class="fw-bold text-primary">@book.Author</span></p>
								</div>
								<div class="text-end">
									<span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2 fs-5">
										@book.Price.ToString("F2") €
									</span>
								</div>
							</div>

							<hr class="my-3 opacity-10">

							<div class="d-flex justify-content-between align-items-center">
								<div class="d-flex gap-2">
									<a asp-action="Details" asp-route-id="@book.Id" class="btn btn-sm btn-outline-info rounded-pill px-4">
										<i class="bi bi-eye"></i> View Details
									</a>
									@if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
									{
										<a asp-action="Edit" asp-route-id="@book.Id" class="btn btn-sm btn-outline-warning rounded-pill px-4">
											<i class="bi bi-pencil"></i> Edit
										</a>
										<a asp-action="Delete" asp-route-id="@book.Id"
										   class="btn btn-sm btn-outline-danger rounded-pill px-4"
										   onclick="return confirm('Are you sure you want to delete this book?');">
											<i class="bi bi-trash"></i> Delete
										</a>
									}
								</div>

								@if (User.Identity?.IsAuthenticated == true && book.IsFavorite == false)
								{
									<form asp-controller="Favorite" asp-action="Add" asp-route-id="@book.Id" method="post" class="m-0">
										<button type="submit" class="btn btn-sm btn-outline-success rounded-pill px-4" title="Add to Favorites">
											<i class="bi bi-heart-fill me-1"></i> Add to Favorites
										</button>
									</form>
								}
							</div>
						</div>
					</div>
				</div>
			}
		</div>
	}
</div>