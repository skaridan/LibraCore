@using LibraCore.ViewModels.Favorite
@model IEnumerable<FavoriteViewModel>

@{
	ViewData["Title"] = "My Favorite Books";
}

@section Styles {
	<link rel="stylesheet" href="~/css/favorite-index.css" asp-append-version="true" />
}

<div class="favorite-background favorite-container">
	<div class="container py-5">

		<div class="text-center mb-5">
			<h1 class="display-4 fw-bold">My Favorite Books</h1>
			<p class="text-muted">Here are the books you've saved to your collection.</p>
			<hr class="w-25 mx-auto border-light" />
		</div>

		@if (!Model.Any())
		{
			<div class="text-center py-5">
				<h3 class="mb-3">Your library is empty... for now.</h3>
				<p>Go explore the catalog and find your next favorite read!</p>
				<a asp-controller="Book" asp-action="Index" class="btn btn-primary btn-lg rounded-pill mt-3 shadow">
					Browse Books
				</a>
			</div>
		}
		else
		{
			<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
				@foreach (FavoriteViewModel book in Model)
				{
					<div class="col">
						<div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden favorite-card">
							<div style="height: 350px; overflow: hidden;">
								<img src="@book.ImageUrl" class="card-img-top w-100 h-100" style="object-fit: cover;" alt="@book.Title">
							</div>

							<div class="card-body d-flex flex-column text-center bg-white">
								<h5 class="card-title fw-bold text-truncate text-dark">@book.Title</h5>
								<p class="card-text text-dark mb-1">by <span class="fw-bold">@book.Author</span></p>
								<p class="fw-bold text-dark mb-3">@book.Price.ToString("F2") €</p>

								<div class="mt-auto d-grid gap-2">
									<a asp-controller="Book" asp-action="Details" asp-route-id="@book.Id"
									   class="btn btn-outline-info rounded-pill">
										<i class="bi bi-info-circle"></i> View Details
									</a>

									<form asp-controller="Favorite" asp-action="Remove" asp-route-id="@book.Id" method="post">
										<button type="submit" class="btn btn-danger rounded-pill w-100">
											<i class="bi bi-trash"></i> Remove from Favorites
										</button>
									</form>
								</div>
							</div>
						</div>
					</div>
				}
			</div>
		}
	</div>
</div>