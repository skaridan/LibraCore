@{
	ViewData["Title"] = "Home Page";
}

<div class="text-center text-white py-5">
	<h1 class="display-3 fw-bold mb-3" style="text-shadow: 2px 4px 10px rgba(0,0,0,0.5);">
		Your Gateway to Infinite Stories
	</h1>
	<p class="fs-4 mb-5 opacity-90 mx-auto" style="max-width: 700px;">
		Explore a vast collection of literary masterpieces and manage your personal library with LibraCore.
	</p>
	<a asp-controller="Book" asp-action="Index" class="btn btn-primary btn-lg rounded-pill px-5 shadow-lg">
		Explore Catalog
	</a>
</div>

<div class="container pb-5">
	<div class="row g-4 justify-content-center">
		<div class="col-md-5">
			<div class="feature-card text-center">
				<i class="bi bi-journal-bookmark-fill mb-3 d-block" style="font-size: 3rem; color: #2a9d8f;"></i>
				<h3 class="fw-bold">Great Titles</h3>
				<p class="text-muted fs-5">From classics to new bestsellers, find everything you love in our collection.</p>
			</div>
		</div>

		<div class="col-md-5">
			<div class="feature-card text-center">
				<i class="bi bi-stars mb-3 d-block" style="font-size: 3rem; color: #e9c46a;"></i>
				<h3 class="fw-bold">Curated Lists</h3>
				<p class="text-muted fs-5">Discover books handpicked for you by our expert librarians and community.</p>
			</div>
		</div>
	</div>

	<div class="quote-section text-center">
		<p class="display-6 fst-italic mb-3" style="font-family: 'Georgia', serif;">
			"A room without books is like a body without a soul."
		</p>
		<div class="fw-bold text-uppercase" style="color: #e76f51; letter-spacing: 3px;">
			— Marcus Tullius Cicero
		</div>
	</div>
</div>