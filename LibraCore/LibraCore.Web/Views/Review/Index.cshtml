@model BookReviewsViewModel

@{
	ViewData["Title"] = "Reviews";
}

@section Styles {
	<link rel="stylesheet" href="~/css/review-index.css" asp-append-version="true" />
}

<div class="container mt-4">
	<div class="d-flex justify-content-between align-items-center mb-5 p-4 bg-white rounded-4 shadow-sm border-start border-5 border-primary">
		<div>
			<h1 class="fw-bold text-dark mb-0">Reviews</h1>
			<p class="text-muted mb-0">See what readers think</p>
		</div>
		@if (User.Identity?.IsAuthenticated == true)
		{
			<a asp-action="Add" asp-route-bookId="@Model.BookId" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
				<i class="bi bi-plus-lg"></i> Add Review
			</a>
		}
	</div>

	@if (!Model.Reviews.Any())
	{
		<div class="feature-card text-center py-5">
			<i class="bi bi-chat-left-text text-muted d-block mb-3" style="font-size: 3rem;"></i>
			<h4 class="fw-bold text-dark">No reviews yet.</h4>
			<p class="text-muted">Be the first to share your thoughts!</p>
		</div>
	}
	else
	{
		<div class="row g-4">
			@foreach (var review in Model.Reviews)
			{
				<div class="col-12">
					<div class="feature-card p-4">
						<div class="d-flex justify-content-between align-items-start">
							<div>
								<p class="fw-bold text-dark mb-1">
									<i class="bi bi-person-circle me-1"></i> @review.UserName
								</p>
								<div class="mb-2">
									@for (int i = 1; i <= 5; i++)
									{
										<i class="bi @(i <= review.Rating ? "bi-star-fill text-warning" : "bi-star text-muted")"></i>
									}
								</div>
								<p class="text-muted mb-0">@review.Comment</p>
							</div>

							@if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
							{
								<a asp-area="Admin" asp-controller="Review" asp-action="Delete" asp-route-id="@review.Id"
								   class="btn btn-sm btn-outline-danger rounded-pill px-3">
									<i class="bi bi-trash"></i> Delete
								</a>
							}
						</div>
					</div>
				</div>
			}
		</div>
	}
</div>