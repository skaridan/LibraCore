@model ReviewInputModel

@{
	ViewData["Title"] = "Add Review";
}

@section Styles {
	<link rel="stylesheet" href="~/css/review-add.css" asp-append-version="true" />
}

<div class="container mt-5">
	<div class="row justify-content-center">
		<div class="col-md-8">
			<div class="feature-card p-5 shadow-lg border-0 rounded-4 bg-white">
				<div class="text-center mb-4">
					<i class="bi bi-chat-left-text text-primary" style="font-size: 3rem;"></i>
					<h2 class="fw-bold text-dark">Add Review</h2>
					<p class="text-muted">Share your thoughts about this book</p>
				</div>

				<div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>

				<form asp-action="Add" asp-route-bookId="@Model.BookId" method="post">

					<input type="hidden" asp-for="BookId" />

					<div class="mb-4 text-center">
						<label class="form-label fw-bold d-block mb-3">Your Rating</label>
						<div class="d-flex justify-content-center gap-3 flex-wrap">
							@for (int i = 1; i <= 5; i++)
							{
								<div class="rating-option">
									<input class="btn-check"
										   type="radio"
										   asp-for="Rating"
										   value="@i"
										   id="rating_@i"
										   autocomplete="off" />
									<label class="btn btn-outline-warning rounded-pill px-3" for="rating_@i">
										@i <i class="bi bi-star-fill"></i>
									</label>
								</div>
							}
						</div>
						<span asp-validation-for="Rating" class="text-danger small d-block mt-2"></span>
					</div>

					<div class="mb-4">
						<label asp-for="Comment" class="form-label fw-bold">Comment</label>
						<textarea asp-for="Comment"
								  class="form-control rounded-4 px-4 py-3"
								  rows="5"
								  placeholder="What did you think about the story, characters, and writing style?"></textarea>
						<span asp-validation-for="Comment" class="text-danger small"></span>
					</div>

					<div class="d-flex gap-3 mt-4">
						<button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold shadow-sm">
							<i class="bi bi-send me-1"></i> Submit Review
						</button>
						<a asp-action="Index" asp-route-bookId="@Model.BookId"
						   class="btn btn-outline-secondary rounded-pill px-4">
							<i class="bi bi-arrow-left me-1"></i> Back to Reviews
						</a>
					</div>
				</form>
			</div>
		</div>
	</div>
</div>

@section Scripts {
	<partial name="_ValidationScriptsPartial" />
}