@model OrderDetailsViewModel

@{
	ViewData["Title"] = "Order Details";
}

<div class="container mt-4">
	<div class="d-flex justify-content-between align-items-center mb-5 p-4 bg-white rounded-4 shadow-sm border-start border-5 border-primary">
		<div>
			<h1 class="fw-bold text-dark mb-0">Order Details</h1>
			<p class="text-muted mb-0">
				<i class="bi bi-calendar-event me-1"></i> @Model.OrderDate.ToString("dd MMM yyyy")
			</p>
		</div>
		<div class="d-flex align-items-center gap-3">
			<span class="badge rounded-pill px-3 py-2
                @(Model.Status == "Pending" ? "bg-warning text-dark" :
											 Model.Status == "Shipped" ? "bg-info text-dark" :
											 Model.Status == "Delivered" ? "bg-success" : "bg-danger")">
				@Model.Status
			</span>
			<span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2 fs-6">
				@Model.TotalPrice.ToString("F2") €
			</span>
		</div>
	</div>

	<div class="row g-4">
		@foreach (var item in Model.Items)
		{
			<div class="col-12">
				<div class="feature-card d-flex align-items-center p-0 overflow-hidden" style="min-height: 120px;">
					<div class="flex-shrink-0">
						@if (!string.IsNullOrWhiteSpace(item.BookImageUrl))
						{
							<img src="@item.BookImageUrl" alt="@item.BookTitle"
								 style="width: 90px; height: 120px; object-fit: cover;">
						}
						else
						{
							<div class="bg-light d-flex align-items-center justify-content-center text-muted"
								 style="width: 90px; height: 120px;">
								<i class="bi bi-book" style="font-size: 2rem;"></i>
							</div>
						}
					</div>
					<div class="flex-grow-1 p-4 d-flex justify-content-between align-items-center">
						<div>
							<h5 class="fw-bold text-dark mb-1">@item.BookTitle</h5>
							<p class="text-muted mb-0">Quantity: @item.Quantity</p>
						</div>
						<span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2 fs-6">
							@item.PriceAtPurchase.ToString("F2") €
						</span>
					</div>
				</div>
			</div>
		}
	</div>

	<div class="mt-4">
		<a asp-action="Index" class="btn btn-outline-light rounded-pill px-4">
			<i class="bi bi-arrow-left"></i> Back to My Orders
		</a>
	</div>
</div>