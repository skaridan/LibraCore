@model IEnumerable<OrderViewModel>

@{
    ViewData["Title"] = "My Orders";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-5 p-4 bg-white rounded-4 shadow-sm border-start border-5 border-primary">
        <div>
            <h1 class="fw-bold text-dark mb-0">My Orders</h1>
            <p class="text-muted mb-0">Track your purchases</p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="feature-card text-center py-5">
            <i class="bi bi-bag text-muted d-block mb-3" style="font-size: 3rem;"></i>
            <h4 class="fw-bold text-dark">No orders yet.</h4>
            <p class="text-muted">Browse the catalog and buy your first book!</p>
            <a asp-controller="Book" asp-action="Index" class="btn btn-primary rounded-pill px-4">
                Go to Catalog
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var order in Model)
            {
                <div class="col-12">
                    <div class="feature-card p-4 d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-1">
                                <i class="bi bi-calendar-event me-1"></i> @order.OrderDate.ToString("dd MMM yyyy")
                            </p>
                            <h5 class="fw-bold text-dark mb-0">@order.TotalPrice.ToString("F2") €</h5>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <span class="badge rounded-pill px-3 py-2
                                        @(order.Status == "Pending" ? "bg-warning text-dark" :
                                                                    order.Status == "Shipped" ? "bg-info text-dark" :
                                                                    order.Status == "Delivered" ? "bg-success" : "bg-danger")">
                        @order.Status
                    </span>
                    <a asp-action="Details" asp-route-id="@order.Id"
                       class="btn btn-sm btn-outline-primary rounded-pill px-4">
                        <i class="bi bi-eye"></i> Details
                    </a>
                </div>
            </div>
        </div>
                }
        </div>
    }
</div>